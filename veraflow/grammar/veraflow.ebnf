(* VeraFlow v10.5 human-readable EBNF specification.
   This file is the language design specification.
   veraflow.lark is the executable parser grammar.
*)

program              = module_decl, import_decl*, declaration*, module_end ;
module_end           = "end", qualified_name ;
module_decl          = "module", qualified_name ;
import_decl          = "import", qualified_name, exposing_clause? ;
exposing_clause      = "exposing", exposing_list ;
exposing_list        = IDENT, { ",", IDENT } ;

declaration          = type_decl
                     | record_type_decl
                     | error_decl
                     | function_decl
                     | procedure_decl ;

type_decl            = "type", IDENT, "is", base_type, range_decl? ;
record_type_decl     = "type", IDENT, "is", "record", record_field+, "end", "record" ;
record_field         = IDENT, ":", type_ref ;
error_decl           = "error", IDENT ;

function_decl        = "function", IDENT, "(", param_list?, ")",
                       "returns", return_type,
                       contract_block?,
                       "is", statement*, "end", IDENT ;

procedure_decl       = "procedure", IDENT, "(", param_list?, ")",
                       contract_block?,
                       "is", statement*, "end", IDENT ;

statement            = let_stmt
                     | field_assign_stmt
                     | assign_stmt
                     | return_stmt
                     | if_stmt
                     | while_stmt
                     | case_stmt
                     | check_stmt
                     | call_stmt ;

let_stmt             = "let", IDENT, ":", return_type, "=", expr ;
assign_stmt          = IDENT, ":=", expr ;
field_assign_stmt    = field_path, ":=", expr ;

if_stmt              = "if", expr, "then", statement*, else_part?, "end", "if" ;
while_stmt           = "while", expr, invariant_clause+, variant_clause?, "do", statement*, "end", "while" ;

field_path           = IDENT, { ".", IDENT } ;

comment              = "--", text_until_end_of_line ;

(* v11a implemented: assignment := for mutation.

   v11d implemented: case/default/end case.

   v11e implemented: --, /* */, /** */ comments with no semantic effect.

   v11f implemented: native String and safe String.* operations.

   v11 planned:
   assignment :=, imports, qualified end markers, case/default/end case,
   comments -- and /* ... */
*)

case_stmt            = "case", expr, "is", case_branch+, default_branch, "end", "case" ;
case_branch          = "when", expr, "=>", statement* ;
default_branch       = "default", "=>", statement* ;


line_comment         = "--", text_until_end_of_line ;
block_comment        = "/*", text_until_closing_block_comment, "*/" ;
ai_doc_comment       = "/**", structured_ai_or_doc_text, "*/" ;

(* v11e comment policy:
   comments are ignored by parser/verifier/interpreter.
   no preprocessor.
   no hidden compiler flags.
   no automatic semantic change from comments.
*)


string_literal       = '"', string_character*, '"' ;
string_function      = "String.concat" | "String.substr" | "String.replace" | "String.instr" ;

(* v11f String system:
   String is a native base type.
   String.concat(a,b) -> String
   String.substr(s,start,length) -> String
   String.replace(s,old,new) -> String
   String.instr(s,needle) -> Integer, 0-based index, -1 if not found.
*)

std_io_binding       = "Std.IO.log" | "Std.IO.logf"
                     | "Std.IO.log_int" | "Std.IO.log_bool" | "Std.IO.log_double" ;

(* v11h Std.IO: standard library foundation; trusted runtime output bindings; not syntax. *)
